NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Required for the beta-application approval flow (app/admin/beta-applications).
# Service role key: Supabase dashboard -> Project Settings -> API -> service_role
# (secret) key. NEVER prefix this with NEXT_PUBLIC_ -- it grants full database
# access bypassing RLS, and must stay server-only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your own email -- the only account that can see/use the beta-applications
# admin page. Not a secret (just an email address), so NEXT_PUBLIC_ is fine.
NEXT_PUBLIC_ADMIN_EMAIL=you@example.com

# Your deployed site's base URL, used to redirect people back into the app
# after they accept a beta invite and set their password. Defaults to
# http://localhost:3000 if unset (fine for local dev only).
NEXT_PUBLIC_SITE_URL=https://your-deployed-url.vercel.app

# Required for the break-glass password-set tool (app/admin/set-password),
# used when the email-based reset flow isn't working or you're locked out.
# Set this to any long random string -- e.g. run `openssl rand -hex 32` in a
# terminal and paste the output. Treat it like a password: don't reuse it
# anywhere else, and only share the /admin/set-password page + this secret
# with yourself.
ADMIN_API_SECRET=generate-a-long-random-string-here

# Optional: for the account-change notification emails (lib/notify.js) and
# feedback-form submission emails, once configured.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
